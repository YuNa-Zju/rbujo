{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "rbujo",
  "version": "0.1.4",
  "identifier": "fun.yunazju.rbujo",
  "build": {
    "beforeDevCommand": "cd ../frontend && npm run dev -- --host 127.0.0.1",
    "beforeBuildCommand": "cd ../frontend && npm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "rbujo",
        "width": 1180,
        "height": 820,
        "minWidth": 900,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "category": "Productivity",
    "icon": ["icons/icon.png"]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ0QUMzRENGQkQ0MTdEOUMKUldTY2ZVRzl6ejJzMUVKb012ZEJMbVViTmpGK2p5eDZmd3UxZTF2MXRVSVRjTjNqaGdMNWQwYncK",
      "endpoints": [
        "https://github.com/YuNa-Zju/rbujo/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
